<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@latest/dist/web/static/pretendard.css">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@600;700;900&display=swap">
<style>
  :root {
    --ink: #1c221e;
    --ink-soft: #5b615c;
    --paper: #f3f3f1;
    --paper-card: #ffffff;
    --accent: #23694a;
    --accent-soft: #d8ebdd;
    --line: #e4e5e1;
    --font-sans: "Pretendard", -apple-system, BlinkMacSystemFont, sans-serif;
    --font-serif: "Noto Serif KR", serif;
    --content: 720px;
  }
  * { box-sizing: border-box; }
  html { font-size: 100%; }
  html, body { margin: 0; padding: 0; word-break: keep-all; overflow-wrap: break-word; }
  body {
    font-family: var(--font-sans);
    background: var(--paper);
    color: var(--ink);
    line-height: 1.75;
    -webkit-font-smoothing: antialiased;
  }
  a { color: inherit; text-decoration: none; }

  /* 상단바 */
  .site-head {
    border-bottom: 1px solid var(--line);
    padding: 20px 24px;
    display: flex; align-items: center; justify-content: center;
  }
  .site-head .brand { font-weight: 800; font-size: 1.1rem; letter-spacing: -0.01em; }

  /* 카테고리 네비 */
  .cat-nav {
    display: flex; gap: 4px; justify-content: center; flex-wrap: wrap;
    padding: 0 24px; border-bottom: 1px solid var(--line); background: var(--paper-card);
  }
  .cat-nav a {
    padding: 14px 22px; font-weight: 700; font-size: 0.95rem; color: var(--ink-soft);
    border-bottom: 2px solid transparent; transition: color .15s, border-color .15s;
  }
  .cat-nav a:hover { color: var(--accent); border-bottom-color: var(--accent); }
  .cat-nav a.active { color: var(--accent); border-bottom-color: var(--accent); }

  /* 준비중 랜딩 */
  .coming { max-width: 600px; margin: 0 auto; padding: 96px 24px; text-align: center; }
  .coming-emoji { font-size: 4rem; }
  .coming-box h1 { font-family: var(--font-serif); font-weight: 900; font-size: 2rem; margin: 16px 0 14px; }
  .coming-box p { color: var(--ink-soft); font-size: 1.1rem; line-height: 1.7; }
  .coming-box a { display: inline-block; margin-top: 30px; color: var(--accent); font-weight: 600; }

  /* 홈 히어로 */
  .hero {
    flex-direction: column; gap: 8px; padding: 72px 24px 56px; border-bottom: 3px solid var(--accent);
  }
  .hero .brand-big {
    font-family: var(--font-serif); font-weight: 900;
    font-size: clamp(2.2rem, 1.5rem + 3vw, 3.6rem); letter-spacing: -0.02em;
  }
  .hero .tagline { color: var(--ink-soft); font-size: 1.05rem; margin: 0; }

  /* ── 홈: 매거진 목차 (피처 + 리스트) ── */
  .toc-wrap { max-width: 780px; margin: 0 auto; padding: 44px 24px 100px; }

  /* 공용 카테고리 배지 */
  .cat {
    display: inline-block; font-size: 0.72rem; font-weight: 700; color: var(--accent);
    background: #ebede9; padding: 3px 11px; border-radius: 6px;
  }
  .cat-sm { font-size: 0.68rem; padding: 2px 9px; }

  /* 피처(최신) 카드 */
  .feature-card {
    display: block; background: #f5faf7;
    border: 1px solid var(--line); border-left: 4px solid var(--accent);
    border-radius: 12px; padding: 34px 34px 30px;
    transition: border-color .18s ease, background .18s ease;
  }
  .feature-card:hover { border-color: var(--accent); }
  .feature-card .cat { margin-bottom: 18px; }
  .feature-card h2 {
    font-family: var(--font-serif); font-weight: 900;
    font-size: clamp(1.55rem, 1.1rem + 1.8vw, 2.15rem); line-height: 1.3;
    letter-spacing: -0.01em; margin: 0 0 14px;
  }
  .feature-card .fc-deck { color: var(--ink-soft); font-size: 1.08rem; line-height: 1.6; margin: 0 0 18px; }
  .feature-card .fc-meta { font-size: 0.82rem; font-weight: 600; color: var(--accent); }

  /* 게시판 목록 인트로 (기사 돋보기 등) */
  .board-intro { padding: 8px 0 20px; border-bottom: 3px solid var(--accent); margin-bottom: 8px; }
  .board-intro h1 {
    font-family: var(--font-serif); font-weight: 900;
    font-size: clamp(1.8rem, 1.3rem + 1.8vw, 2.4rem); letter-spacing: -0.01em; margin: 0 0 8px;
  }
  .board-intro p { color: var(--ink-soft); font-size: 1.05rem; margin: 0; }

  /* 나머지 기사 리스트 */
  .post-list { display: flex; flex-direction: column; margin-top: 40px; }
  .post-list::before {
    content: "지난 기사"; display: block;
    font-size: 0.8rem; font-weight: 700; color: var(--ink-soft);
    padding-bottom: 12px; border-bottom: 2px solid var(--ink);
  }
  .post-row {
    display: block; padding: 22px 4px; border-bottom: 1px solid var(--line);
    transition: background .15s ease, padding-left .15s ease;
  }
  .post-row:hover { background: var(--paper-card); padding-left: 12px; }
  .pr-head { display: flex; align-items: center; gap: 10px; margin-bottom: 9px; }
  .pr-head time { font-size: 0.8rem; color: var(--ink-soft); }
  .post-row h3 { font-size: 1.15rem; font-weight: 800; line-height: 1.4; margin: 0 0 6px; letter-spacing: -0.005em; }
  .post-row p { color: var(--ink-soft); font-size: 0.95rem; line-height: 1.55; margin: 0; }

  /* 다른 게시판(과저씨의 메모·웹툰) 새 글 미리보기 */
  .other-boards { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 14px; margin-top: 16px; }
  .board-card {
    display: block; background: var(--paper-card); border: 1px solid var(--line);
    border-radius: 12px; padding: 22px 24px; transition: border-color .18s ease;
  }
  .board-card:hover { border-color: var(--accent); }
  .board-label { display: inline-block; font-size: 0.78rem; font-weight: 700; color: var(--accent); margin-bottom: 12px; }
  .board-card h3 { font-size: 1.05rem; font-weight: 800; line-height: 1.4; margin: 0 0 6px; }
  .board-card p { color: var(--ink-soft); font-size: 0.9rem; line-height: 1.5; margin: 0; }
  .board-soon { opacity: 0.72; }
  @media (max-width: 560px) { .other-boards { grid-template-columns: 1fr; } }

  /* 기사 페이지 — named grid: 본문 컬럼 + 풀블리드 여지 */
  .article-grid {
    display: grid;
    grid-template-columns:
      [full-start] minmax(24px, 1fr)
      [content-start] minmax(0, var(--content))
      [content-end] minmax(24px, 1fr)
      [full-end];
    padding: 8px 0 96px;
  }
  .article-grid > * { grid-column: content; }
  .article-head { margin: 40px 0 8px; }
  .article-head .cat {
    display: inline-block; font-size: 0.76rem; font-weight: 700; color: var(--accent);
    background: var(--accent-soft); padding: 4px 12px; border-radius: 999px; margin-bottom: 20px;
  }
  .article-head h1 {
    font-family: var(--font-serif); font-weight: 900;
    font-size: clamp(1.9rem, 1.3rem + 2.6vw, 3rem); line-height: 1.28; margin: 0 0 18px; letter-spacing: -0.01em;
  }
  .article-head .deck {
    font-size: clamp(1.1rem, 1rem + 0.4vw, 1.35rem); color: var(--ink-soft);
    font-weight: 500; line-height: 1.6; margin: 0 0 16px;
  }
  .article-head time { font-size: 0.85rem; color: var(--ink-soft); }

  .article-body { margin-top: 24px; font-size: 1.08rem; line-height: 1.8; }
  .article-body h2 {
    font-size: 1.4rem; font-weight: 800; margin: 56px 0 8px;
    padding-top: 28px; border-top: 1px solid var(--line); letter-spacing: -0.005em;
  }
  .article-body h2:first-child { border-top: none; padding-top: 0; margin-top: 8px; }
  .article-body p { margin: 16px 0; }

  /* 푸터 */
  .site-foot {
    border-top: 1px solid var(--line); margin-top: 40px; padding: 32px 24px;
    display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;
    font-size: 0.88rem; color: var(--ink-soft); max-width: 1080px; margin-left: auto; margin-right: auto;
  }
  .site-foot a { color: var(--accent); font-weight: 600; }

  /* 드롭캡 — 쉽게풀면 첫 문단 첫 글자 (Quanta식) */
  .article-body > h2:first-of-type + p::first-letter {
    font-family: var(--font-serif); font-size: 3.3em; font-weight: 900;
    float: left; line-height: 0.72; padding: 6px 10px 0 0; color: var(--accent);
  }
  /* 다크 설명박스 콜아웃 (Quanta식 용어 풀이) */
  .callout {
    background: #1f2c25; color: #e7efe8; font-size: 0.96rem; line-height: 1.65;
    padding: 16px 20px; border-radius: 12px; margin: 24px 0;
  }
  .callout strong { color: #8fc7a6; }
  /* 이 날의 다른 소식 — 뉴스 리스트 */
  .article-body ul { list-style: none; padding: 0; margin: 10px 0 20px; }
  .article-body li {
    padding: 12px 0; border-bottom: 1px solid var(--line);
    font-size: 1rem; line-height: 1.55; color: var(--ink-soft);
  }
  .article-body li a {
    color: var(--ink); font-weight: 700;
    border-bottom: 2px solid var(--accent-soft); transition: border-color .15s;
  }
  .article-body li a:hover { border-bottom-color: var(--accent); }
  .article-body p > strong:only-child {
    display: inline-block; font-size: 1.05rem; margin: 14px 0 2px; color: var(--accent);
  }
  /* 원문 링크 박스 */
  .source-link {
    display: inline-block; margin-top: 28px; font-size: 0.92rem; font-weight: 600;
    color: var(--accent); background: var(--accent-soft);
    padding: 10px 18px; border-radius: 8px; transition: background .15s;
  }
  .source-link:hover { background: #e6ccb8; }
  /* 화자 서명 (한국 큐레이션식 톤) */
  .byline-sign {
    margin-top: 40px; padding-top: 22px; border-top: 1px solid var(--line);
    font-size: 0.95rem; color: var(--accent); font-weight: 600;
  }
  @media (max-width: 560px) {
    .toc-wrap { padding: 32px 18px 80px; }
    .feature-card { padding: 26px 22px 24px; }
  }
  /* 기사 상단 메타 (날짜 + 원문 링크) — 요약 근처로 */
  .head-meta { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; margin-top: 6px; }
  .head-meta time { font-size: 0.85rem; color: var(--ink-soft); }
  .head-meta .source-link { margin-top: 0; padding: 7px 15px; font-size: 0.85rem; }

  /* 홈 카드 상단 (카테고리 + 날짜 크게) */
  .card-top { display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-bottom: 12px; }
  .card-top .cat { margin-bottom: 0; }
  .card-top time { font-size: 1rem; font-weight: 800; color: var(--accent); }

  /* 본문 용어 형광펜 (아래 콜아웃 설명과 시각 매치) */
  .article-body mark {
    background: linear-gradient(transparent 52%, var(--accent-soft) 52%);
    color: inherit; font-weight: 700; padding: 0 2px;
  }

  /* 피드백 링크 */
  .feedback-link { color: var(--accent); font-weight: 600; }

  /* 이 날의 다른 소식 — 메인과 구분되는 별개 코너 (배경 박스 + 미니 카드) */
  .other-news {
    background: #e9ede3; border: 1px solid var(--line); border-radius: 12px;
    padding: 22px 24px 18px; margin: 56px 0 12px;
  }
  .other-news h2 { border-top: none; padding-top: 0; margin-top: 0; font-size: 1.15rem; }
  .other-news p > strong:only-child { color: var(--ink); font-size: 0.98rem; margin: 16px 0 4px; }
  .other-news ul { margin: 8px 0 4px; }
  .other-news li {
    background: var(--paper-card); border: 1px solid var(--line);
    border-radius: 10px; padding: 12px 15px; margin: 8px 0; color: var(--ink);
  }
  .other-news li a { border-bottom: none; color: var(--ink); }
  .other-news li a:hover { color: var(--accent); }
  .nb {
    display: inline-block; font-size: 0.72rem; font-weight: 700;
    background: var(--accent-soft); color: var(--accent);
    padding: 2px 9px; border-radius: 6px; margin-right: 7px; vertical-align: middle;
  }
</style>
