{% if noindex %}<meta name="robots" content="noindex, nofollow">{% endif %}
<link rel="canonical" href="{{ siteUrl }}{{ page.url }}">
<meta property="og:type" content="{{ ogType or 'article' }}">
<meta property="og:title" content="{{ title or siteName }}">
<meta property="og:description" content="{{ deck or description or siteDescription }}">
<meta property="og:url" content="{{ siteUrl }}{{ page.url }}">
<meta property="og:site_name" content="{{ siteName }}">
<meta property="og:image" content="{{ siteUrl }}{{ ogImage or '/assets/og-default.jpg' }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:locale" content="ko_KR">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ title or siteName }}">
<meta name="twitter:description" content="{{ deck or description or siteDescription }}">
<meta name="twitter:image" content="{{ siteUrl }}{{ ogImage or '/assets/og-default.jpg' }}">
